class State:
    def __init__(self):
        self.edges = {}  # {symbol: [states]}
        self.epsilon = []  # epsilon transitions


class NFA:
    def __init__(self, start, end):
        self.start = start
        self.end = end


def symbol_nfa(symbol):
    start = State()
    end = State()
    start.edges[symbol] = [end]
    return NFA(start, end)


def concat(nfa1, nfa2):
    nfa1.end.epsilon.append(nfa2.start)
    return NFA(nfa1.start, nfa2.end)


def union(nfa1, nfa2):
    start = State()
    end = State()

    start.epsilon.extend([nfa1.start, nfa2.start])
    nfa1.end.epsilon.append(end)
    nfa2.end.epsilon.append(end)

    return NFA(start, end)


def kleene_star(nfa):
    start = State()
    end = State()

    start.epsilon.extend([nfa.start, end])
    nfa.end.epsilon.extend([nfa.start, end])

    return NFA(start, end)


def regex_to_nfa(regex):
    stack = []

    for char in regex:
        if char.isalnum():
            stack.append(symbol_nfa(char))

        elif char == '*':
            nfa = stack.pop()
            stack.append(kleene_star(nfa))

        elif char == '.':  # concatenation
            nfa2 = stack.pop()
            nfa1 = stack.pop()
            stack.append(concat(nfa1, nfa2))

        elif char == '|':
            nfa2 = stack.pop()
            nfa1 = stack.pop()
            stack.append(union(nfa1, nfa2))

    return stack.pop()


# Example usage
regex = "ab.|"   # (a.b)|c type postfix
nfa = regex_to_nfa(regex)

print("NFA constructed successfully!")
